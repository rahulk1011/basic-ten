				</figure>
			</div>
		</section>
		<section class="section-recipes">
			<h5 class="heading-recipe">Type 2</h5>
			<hr/>
			<div class="recipes-row">
				<figure class="recipes-item">
					<a href="recipe.html">
						<img src="" class="recipes-img" alt="Recipe 1">
					</a>
					<figcaption>
						<a href="recipe.html" class="recipes-name">Recipe 1 Type 2</a>
					</figcaption>
				</figure>
				<figure class="recipes-item">
					<a href="recipe.html">
						<img src="" class="recipes-img" alt="Recipe 2">
					</a>
					<figcaption>
						<a href="recipe.html" class="recipes-name">Recipe 2 Type 2</a>
					</figcaption>
